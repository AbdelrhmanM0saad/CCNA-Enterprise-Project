!
! Last configuration change at 23:12:16 UTC Wed Jul 8 2026
!
version 15.6
service timestamps debug datetime msec
service timestamps log datetime msec
no service password-encryption
!
hostname HQ
!
boot-start-marker
boot-end-marker
!
!
!
no aaa new-model
ethernet lmi ce
!
!
!
mmi polling-interval 60
no mmi auto-configure
no mmi pvc
mmi snmp-timeout 180
!
!
!
!
!
!
!
!
!
!
!
no ip domain lookup
ip cef
no ipv6 cef
!
multilink bundle-name authenticated
!
!
!
!
!         
redundancy
!
!
! 
!
!
!
!
crypto isakmp policy 10
 encr aes
 hash sha512
 authentication pre-share
 group 5
crypto isakmp key ABDO address 41.33.160.2    
!
!
crypto ipsec transform-set ABDO esp-aes esp-sha512-hmac 
 mode tunnel
!
!
!
crypto map GRE-IPSEC 10 ipsec-isakmp 
 set peer 41.33.160.2
 set transform-set ABDO 
 match address ABDO
!
!
!
!
!
interface Loopback1
 ip address 7.7.7.7 255.255.255.0
 ip ospf 1 area 0
!
interface Tunnel1
 ip address 192.168.1.1 255.255.255.252
 ip ospf 1 area 0
 tunnel source GigabitEthernet0/2
 tunnel destination 41.33.160.2
!
interface GigabitEthernet0/0
 ip address 12.1.1.2 255.255.255.0
 ip access-group 100 in
 ip nat inside
 ip virtual-reassembly in
 duplex auto
 speed auto
 media-type rj45
!
interface GigabitEthernet0/1
 ip address 13.1.1.2 255.255.255.0
 ip nat inside
 ip virtual-reassembly in
 duplex auto
 speed auto
 media-type rj45
!
interface GigabitEthernet0/2
 ip address 41.33.150.2 255.255.255.252
 ip nat outside
 ip virtual-reassembly in
 duplex auto
 speed auto
 media-type rj45
 crypto map GRE-IPSEC
!
interface GigabitEthernet0/3
 ip address 10.50.10.1 255.255.255.0
 duplex auto
 speed auto
 media-type rj45
!
router ospf 1
 router-id 2.2.2.2
 network 10.50.10.0 0.0.0.255 area 0
 network 12.1.1.0 0.0.0.255 area 0
 network 13.1.1.0 0.0.0.255 area 0
 network 192.168.1.0 0.0.0.3 area 0
 default-information originate
!
ip forward-protocol nd
!
!
no ip http server
no ip http secure-server
ip nat inside source list 10 interface GigabitEthernet0/2 overload
ip route 0.0.0.0 0.0.0.0 41.33.150.1
!
ip access-list extended ABDO
 permit gre host 41.33.150.2 host 41.33.160.2
!
!         
!
access-list 10 permit any
access-list 100 permit tcp 10.50.10.0 0.0.0.255 host 10.50.10.40 eq 3306
access-list 100 deny   ip any host 10.50.10.40
access-list 100 permit ip any any
!
control-plane
!
banner exec ^C
